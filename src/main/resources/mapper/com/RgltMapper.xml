<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.go.molit.icas.com.rglt.RgltMapper">

    <!-- ════════════════════════════════════════════
         공통 컬럼
         ════════════════════════════════════════════ -->
    <sql id="baseColumns">
        rglt_id,
        rglt_se_cd,
        rglt_nm,
        eff_dt,
        exp_dt,
        summary,
        contents_html,
        use_bgng_dt,
        use_end_dt,
        frst_reg_dt,
        frst_reg_user_id,
        last_chg_dt,
        last_chg_user_id
    </sql>

    <!-- ════════════════════════════════════════════
         단건 조회
         ════════════════════════════════════════════ -->
    <select id="selectByRgltId" resultType="kr.go.molit.icas.com.rglt.domain.RgltVO">
        SELECT <include refid="baseColumns"/>
          FROM com.tn_rglt
         WHERE rglt_id    = #{rgltId}
           AND use_end_dt > NOW()
    </select>

    <!-- ════════════════════════════════════════════
         동적 검색 조건
         ════════════════════════════════════════════ -->
    <sql id="searchConditions">
        <if test="rgltSeCd != null and rgltSeCd != ''">
            AND rglt_se_cd = #{rgltSeCd}
        </if>
        <if test="keyword != null and keyword != ''">
            AND rglt_nm LIKE '%' || #{keyword} || '%'
        </if>
    </sql>

    <!-- ════════════════════════════════════════════
         목록 조회 (검색 + 페이징)
         ════════════════════════════════════════════ -->
    <select id="selectRglts"
            parameterType="kr.go.molit.icas.com.rglt.domain.RgltSearch"
            resultType="kr.go.molit.icas.com.rglt.domain.RgltVO">
        SELECT <include refid="baseColumns"/>
          FROM com.tn_rglt
         WHERE use_end_dt > NOW()
        <include refid="searchConditions"/>
         ORDER BY frst_reg_dt DESC
         LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <!-- ════════════════════════════════════════════
         총 건수 (페이징용)
         ════════════════════════════════════════════ -->
    <select id="countRglts"
            parameterType="kr.go.molit.icas.com.rglt.domain.RgltSearch"
            resultType="int">
        SELECT COUNT(*)
          FROM com.tn_rglt
         WHERE use_end_dt > NOW()
        <include refid="searchConditions"/>
    </select>

    <!-- ════════════════════════════════════════════
         채번: RG prefix 최대 순번 + 1
         ════════════════════════════════════════════ -->
    <select id="countByPrefix" resultType="int">
        <!-- SOFT DELETE 행도 포함 — PK 충돌 회피 -->
        SELECT COALESCE(MAX(SUBSTRING(rglt_id, 3)::int), 0)
          FROM com.tn_rglt
         WHERE rglt_id LIKE 'RG%'
           AND SUBSTRING(rglt_id, LENGTH('RG') + 1) ~ '^[0-9]+$'
    </select>

    <!-- ════════════════════════════════════════════
         규정 등록
         ════════════════════════════════════════════ -->
    <insert id="insertRglt" parameterType="kr.go.molit.icas.com.rglt.domain.RgltVO">
        INSERT INTO com.tn_rglt (
            rglt_id,
            rglt_se_cd,
            rglt_nm,
            eff_dt,
            exp_dt,
            summary,
            contents_html,
            use_bgng_dt,
            use_end_dt,
            frst_reg_dt,
            frst_reg_user_id,
            last_chg_dt,
            last_chg_user_id
        ) VALUES (
            #{rgltId},
            #{rgltSeCd},
            #{rgltNm},
            #{effDt},
            #{expDt},
            #{summary},
            #{contentsHtml},
            NOW(),
            '9999-12-31 23:59:59',
            NOW(),
            #{frstRegUserId},
            NOW(),
            #{lastChgUserId}
        )
    </insert>

    <!-- ════════════════════════════════════════════
         규정 수정
         ════════════════════════════════════════════ -->
    <update id="updateRglt" parameterType="kr.go.molit.icas.com.rglt.domain.RgltVO">
        UPDATE com.tn_rglt
           SET rglt_se_cd       = #{rgltSeCd},
               rglt_nm          = #{rgltNm},
               eff_dt           = #{effDt},
               exp_dt           = #{expDt},
               summary          = #{summary},
               contents_html    = #{contentsHtml},
               last_chg_dt      = NOW(),
               last_chg_user_id = #{lastChgUserId}
         WHERE rglt_id    = #{rgltId}
           AND use_end_dt > NOW()
    </update>

    <!-- ════════════════════════════════════════════
         소프트 삭제
         ════════════════════════════════════════════ -->
    <update id="softDeleteRglt">
        UPDATE com.tn_rglt
           SET use_end_dt       = NOW() - INTERVAL '1 minute',
               last_chg_dt      = NOW(),
               last_chg_user_id = #{userId}
         WHERE rglt_id    = #{rgltId}
           AND use_end_dt > NOW()
    </update>

</mapper>
